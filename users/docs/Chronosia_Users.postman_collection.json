{
  "info": {
    "name": "Chronosia — Users API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "description": "Colección completa del módulo users. Base URL configurable via variable de entorno {{base_url}}."
  },
  "variable": [
    { "key": "base_url", "value": "http://localhost:8000", "type": "string" },
    { "key": "access_token", "value": "", "type": "string" },
    { "key": "refresh_token", "value": "", "type": "string" },
    { "key": "user_id", "value": "", "type": "string" }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{base_url}}/api/auth/register/", "host": ["{{base_url}}"], "path": ["api","auth","register",""] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"nombre\": \"Carlos Coordinador\",\n  \"email\": \"coord@test.com\",\n  \"username\": \"carloscoord\",\n  \"rol\": \"COORDINADOR\",\n  \"password\": \"TestPass123!\",\n  \"password2\": \"TestPass123!\"\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 201', () => pm.response.to.have.status(201));",
                  "pm.test('Tiene id', () => pm.expect(pm.response.json()).to.have.property('id'));",
                  "if (pm.response.json().id) {",
                  "  pm.collectionVariables.set('user_id', pm.response.json().id);",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "Register — email duplicado (400)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{base_url}}/api/auth/register/", "host": ["{{base_url}}"], "path": ["api","auth","register",""] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"nombre\": \"Otro\",\n  \"email\": \"coord@test.com\",\n  \"username\": \"otro\",\n  \"rol\": \"ESTUDIANTE\",\n  \"password\": \"TestPass123!\",\n  \"password2\": \"TestPass123!\"\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": ["pm.test('Status 400', () => pm.response.to.have.status(400));"]
              }
            }
          ]
        },
        {
          "name": "Login",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{base_url}}/api/auth/login/", "host": ["{{base_url}}"], "path": ["api","auth","login",""] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"coord@test.com\",\n  \"password\": \"TestPass123!\"\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "const json = pm.response.json();",
                  "pm.test('Tiene access token', () => pm.expect(json).to.have.property('access'));",
                  "pm.test('Tiene refresh token', () => pm.expect(json).to.have.property('refresh'));",
                  "pm.test('Tiene datos de usuario', () => pm.expect(json).to.have.property('user'));",
                  "if (json.access) pm.collectionVariables.set('access_token', json.access);",
                  "if (json.refresh) pm.collectionVariables.set('refresh_token', json.refresh);",
                  "if (json.user && json.user.id) pm.collectionVariables.set('user_id', json.user.id);"
                ]
              }
            }
          ]
        },
        {
          "name": "Login — credenciales inválidas (400)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{base_url}}/api/auth/login/", "host": ["{{base_url}}"], "path": ["api","auth","login",""] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"noexiste@test.com\",\n  \"password\": \"WrongPass!\"\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": ["pm.test('Status 400', () => pm.response.to.have.status(400));"]
              }
            }
          ]
        },
        {
          "name": "Verify Email",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{access_token}}" }
            ],
            "url": { "raw": "{{base_url}}/api/auth/verify-email/", "host": ["{{base_url}}"], "path": ["api","auth","verify-email",""] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"code\": \"123456\"\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": ["pm.test('Status 200', () => pm.response.to.have.status(200));"]
              }
            }
          ]
        },
        {
          "name": "Refresh Token",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{base_url}}/api/auth/refresh/", "host": ["{{base_url}}"], "path": ["api","auth","refresh",""] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refresh\": \"{{refresh_token}}\"\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "const json = pm.response.json();",
                  "if (json.access) pm.collectionVariables.set('access_token', json.access);",
                  "if (json.refresh) pm.collectionVariables.set('refresh_token', json.refresh);"
                ]
              }
            }
          ]
        },
        {
          "name": "Logout",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{access_token}}" }
            ],
            "url": { "raw": "{{base_url}}/api/auth/logout/", "host": ["{{base_url}}"], "path": ["api","auth","logout",""] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refresh\": \"{{refresh_token}}\"\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.collectionVariables.set('refresh_token', '');"
                ]
              }
            }
          ]
        },
        {
          "name": "Password Reset — Request",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{base_url}}/api/auth/password-reset/", "host": ["{{base_url}}"], "path": ["api","auth","password-reset",""] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"coord@test.com\"\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": ["pm.test('Status 200 (siempre, no revela existencia)', () => pm.response.to.have.status(200));"]
              }
            }
          ]
        },
        {
          "name": "Password Reset — Confirm",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{base_url}}/api/auth/password-reset/confirm/", "host": ["{{base_url}}"], "path": ["api","auth","password-reset","confirm",""] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"token\": \"PEGAR-UUID-DEL-EMAIL\",\n  \"password\": \"NuevaPass123!\"\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": ["pm.test('Status 200', () => pm.response.to.have.status(200));"]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "Profile",
      "item": [
        {
          "name": "Get perfil propio",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{access_token}}" }],
            "url": { "raw": "{{base_url}}/api/auth/profile/", "host": ["{{base_url}}"], "path": ["api","auth","profile",""] }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('Tiene email', () => pm.expect(pm.response.json()).to.have.property('email'));",
                  "pm.test('Tiene rol', () => pm.expect(pm.response.json()).to.have.property('rol'));"
                ]
              }
            }
          ]
        },
        {
          "name": "Update perfil — nombre e imagen",
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Authorization", "value": "Bearer {{access_token}}" }],
            "url": { "raw": "{{base_url}}/api/auth/profile/", "host": ["{{base_url}}"], "path": ["api","auth","profile",""] },
            "body": {
              "mode": "formdata",
              "formdata": [
                { "key": "nombre", "value": "Carlos Actualizado", "type": "text" }
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('Nombre actualizado', () => pm.expect(pm.response.json().nombre).to.eql('Carlos Actualizado'));"
                ]
              }
            }
          ]
        },
        {
          "name": "Update username",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{access_token}}" }
            ],
            "url": { "raw": "{{base_url}}/api/auth/profile/username/", "host": ["{{base_url}}"], "path": ["api","auth","profile","username",""] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"nuevo_username\"\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": ["pm.test('Status 200', () => pm.response.to.have.status(200));"]
              }
            }
          ]
        },
        {
          "name": "Email change — Request",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{access_token}}" }
            ],
            "url": { "raw": "{{base_url}}/api/auth/profile/email/", "host": ["{{base_url}}"], "path": ["api","auth","profile","email",""] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"new_email\": \"nuevo@test.com\"\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": ["pm.test('Status 200', () => pm.response.to.have.status(200));"]
              }
            }
          ]
        },
        {
          "name": "Email change — Confirm",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{access_token}}" }
            ],
            "url": { "raw": "{{base_url}}/api/auth/profile/email/confirm/", "host": ["{{base_url}}"], "path": ["api","auth","profile","email","confirm",""] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"code\": \"PEGAR-CODIGO-DEL-EMAIL\"\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": ["pm.test('Status 200', () => pm.response.to.have.status(200));"]
              }
            }
          ]
        },
        {
          "name": "Profile — sin auth (401)",
          "request": {
            "method": "GET",
            "header": [],
            "url": { "raw": "{{base_url}}/api/auth/profile/", "host": ["{{base_url}}"], "path": ["api","auth","profile",""] }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": ["pm.test('Status 401', () => pm.response.to.have.status(401));"]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "Users",
      "item": [
        {
          "name": "List users",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{access_token}}" }],
            "url": {
              "raw": "{{base_url}}/api/users/",
              "host": ["{{base_url}}"],
              "path": ["api","users",""],
              "query": [
                { "key": "search", "value": "", "disabled": true },
                { "key": "rol", "value": "ESTUDIANTE", "disabled": true },
                { "key": "estado", "value": "true", "disabled": true },
                { "key": "page", "value": "1", "disabled": true },
                { "key": "page_size", "value": "20", "disabled": true }
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('Tiene paginación', () => {",
                  "  const json = pm.response.json();",
                  "  pm.expect(json).to.have.property('count');",
                  "  pm.expect(json).to.have.property('results');",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "List users — búsqueda por nombre",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{access_token}}" }],
            "url": {
              "raw": "{{base_url}}/api/users/?search=carlos",
              "host": ["{{base_url}}"],
              "path": ["api","users",""],
              "query": [{ "key": "search", "value": "carlos" }]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": ["pm.test('Status 200', () => pm.response.to.have.status(200));"]
              }
            }
          ]
        },
        {
          "name": "List users — filtro por rol",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{access_token}}" }],
            "url": {
              "raw": "{{base_url}}/api/users/?rol=DOCENTE",
              "host": ["{{base_url}}"],
              "path": ["api","users",""],
              "query": [{ "key": "rol", "value": "DOCENTE" }]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": ["pm.test('Status 200', () => pm.response.to.have.status(200));"]
              }
            }
          ]
        },
        {
          "name": "List users — sin auth (401)",
          "request": {
            "method": "GET",
            "header": [],
            "url": { "raw": "{{base_url}}/api/users/", "host": ["{{base_url}}"], "path": ["api","users",""] }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": ["pm.test('Status 401', () => pm.response.to.have.status(401));"]
              }
            }
          ]
        },
        {
          "name": "User detail",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{access_token}}" }],
            "url": { "raw": "{{base_url}}/api/users/{{user_id}}/", "host": ["{{base_url}}"], "path": ["api","users","{{user_id}}",""] }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('Tiene id', () => pm.expect(pm.response.json()).to.have.property('id'));"
                ]
              }
            }
          ]
        },
        {
          "name": "User detail — no encontrado (404)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{access_token}}" }],
            "url": { "raw": "{{base_url}}/api/users/99999/", "host": ["{{base_url}}"], "path": ["api","users","99999",""] }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": ["pm.test('Status 404', () => pm.response.to.have.status(404));"]
              }
            }
          ]
        },
        {
          "name": "Create user",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{access_token}}" }
            ],
            "url": { "raw": "{{base_url}}/api/users/create/", "host": ["{{base_url}}"], "path": ["api","users","create",""] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"nombre\": \"Diana Docente\",\n  \"email\": \"diana@test.com\",\n  \"username\": \"dianadocente\",\n  \"rol\": \"DOCENTE\",\n  \"password\": \"TestPass123!\",\n  \"password2\": \"TestPass123!\"\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 201', () => pm.response.to.have.status(201));",
                  "const json = pm.response.json();",
                  "if (json.id) pm.collectionVariables.set('user_id', json.id);"
                ]
              }
            }
          ]
        },
        {
          "name": "Update user — rol y estado",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{access_token}}" }
            ],
            "url": { "raw": "{{base_url}}/api/users/{{user_id}}/update/", "host": ["{{base_url}}"], "path": ["api","users","{{user_id}}","update",""] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"estado\": true\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": ["pm.test('Status 200', () => pm.response.to.have.status(200));"]
              }
            }
          ]
        },
        {
          "name": "Change rol",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{access_token}}" }
            ],
            "url": { "raw": "{{base_url}}/api/users/{{user_id}}/rol/", "host": ["{{base_url}}"], "path": ["api","users","{{user_id}}","rol",""] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"rol\": \"ESTUDIANTE\"\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": ["pm.test('Status 200', () => pm.response.to.have.status(200));"]
